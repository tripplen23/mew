# Build artifacts
target/
**/target/

# cargo backup files (from `rustup` switching toolchains, etc.)
*.rs.bk
**/*.rs.bk
Cargo.lock.bak

# MSVC Windows builds of rustc emit these debug symbols
*.pdb
**/*.pdb

# Local config & secrets — never commit these
.env
.env.local
.envrc
**/.env
**/.env.local

# Docker volumes (postgres data lives here per docker-compose.yml)
data/

# Logs
*.log
**/*.log

# OS files
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

.kiro/
.mew/
PROMPT.md
.env

# Go build artifacts
mew-mcp/mew-mcp
mew-mcp/bin/

# Proptest regression seeds — regenerable, pollutes diffs if committed.
*.proptest-regressions
**/*.proptest-regressions

# Local GitHub App private keys + helper scripts (never commit)
.secrets/
**/.secrets/
